package dice

version    = 0.1.0
brief      = "A library for parsing and evaluating dice expressions."
authors    = "Arimura Sena"
license    = "GPL-3.0-or-later"
sourcedir  = "src"

modules = Dice
        , Dice.Parser
        , Dice.Ast
        , Dice.Evaluator
        , Dice.Value
        , Dice.Utils
        , Dice.Token
        , Dice.Lexer
        , Dice.Internal
        , Dice.Random
